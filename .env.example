# ============================================================
# ONGC AI Cluster Monitor — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
# ============================================================

# --- Database ---
# IMPORTANT: The hostname MUST be "db" (the Docker Compose service name).
# Do NOT use "localhost" — that will fail inside Docker.
# Use the same password in both lines below.
DATABASE_URL=postgresql+asyncpg://postgres:YourStrongPassword@db:5432/ongc
POSTGRES_PASSWORD=YourStrongPassword

# --- Prometheus ---
# Do NOT change this — "prometheus" is the Docker Compose service name.
PROMETHEUS_URL=http://prometheus:9090

# --- Collector ---
# How often (in seconds) to collect metrics from Prometheus.
COLLECT_INTERVAL=60

# --- Health Checker ---
# How often (in seconds) to run ping/port/SSH health checks.
HEALTH_CHECK_INTERVAL=30
NODE_EXPORTER_PORT=9100

# --- Warmup ---
# Seconds a newly registered node spends in WARMUP mode before
# anomaly detection activates (allows baselines to be established).
WARMUP_PERIOD_SECONDS=300

# --- Anomaly Detection Thresholds ---
# Tune these to match your ONGC cluster's normal operating ranges.
CPU_CRITICAL_PCT=95
CPU_HIGH_PCT=85
CPU_MEDIUM_PCT=75
MEM_CRITICAL_PCT=95
MEM_HIGH_PCT=90
MEM_MEDIUM_PCT=80
DISK_CRITICAL_PCT=95
DISK_HIGH_PCT=85
IOWAIT_HIGH_PCT=40
IOWAIT_MEDIUM_PCT=20
LOAD_CRITICAL=30
LOAD_HIGH=15
LOAD_MEDIUM=8

# --- SSH Configuration ---
# SSH_KEY_PATH: Path to the private key INSIDE the Docker container.
#   Do NOT change this value — Docker mounts your .ssh folder here automatically.
SSH_KEY_PATH=/root/.ssh/id_rsa

# SSH_USERNAME: Default/fallback SSH username for nodes.
#   Each node can have its own SSH username set in the
#   Settings → Node Management UI, which overrides this value.
#   This fallback is used for nodes that have no username configured.
SSH_USERNAME=your_linux_username

# --- Email Alerts (optional — leave blank to disable) ---
EMAIL_USER=
EMAIL_PASSWORD=
ALERT_EMAIL_TO=
